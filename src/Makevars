TARGET_DIR=rust/target
RUST_PROFILE=release
CARGO_WRAPPER=./cargo.sh
STATLIB=$(TARGET_DIR)/$(RUST_PROFILE)/libparallax.a

PKG_LIBS=$(STATLIB)

all: $(SHLIB)

$(STATLIB):
	$(CARGO_WRAPPER) build --manifest-path=rust/Cargo.toml --lib --release --locked --offline -j 1 \
		--config source.crates-io.replace-with=\"vendored-sources\" \
		--config source.vendored-sources.directory=\"rust/vendor\"

$(SHLIB): $(STATLIB)

clean:
	rm -Rf rust/target
